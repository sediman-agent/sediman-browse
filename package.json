{
  "name": "sediman-browse",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck",
    "start": "cargo run -p sediman-tui --",
    "tui": "cargo run -p sediman-tui --",
    "python": "uv run python -m sediman.rpc_server",
    "fullstack": "bash scripts/sediman.sh",
    "rpc": "cd packages/server && bun run rpc"
  }
}
